{
  "name": "@loj-lang/benchmark-core",
  "version": "0.5.1",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/juliusrl/loj.git",
    "directory": "packages/loj-benchmark-core"
  },
  "description": "ReactDSL benchmark harness for docs-only authoring evaluation",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "license": "Apache-2.0",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20.19.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "rdsl-benchmark": "./dist/index.js"
  },
  "scripts": {
    "build": "npm run build --workspace=@loj-lang/rdsl-compiler && tsc",
    "exec": "node scripts/exec-from-init-cwd.mjs",
    "test": "npm run build --workspace=@loj-lang/rdsl-compiler && vitest run"
  },
  "dependencies": {
    "@loj-lang/rdsl-compiler": "^0.5.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
