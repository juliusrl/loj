{
  "scopeName": "source.loj-flow",
  "name": "Loj Flow",
  "patterns": [
    { "include": "#comments" },
    { "include": "#entities" },
    { "include": "#keywords" },
    { "include": "#operators" },
    { "include": "#scalars" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.loj-flow",
          "match": "#.*$"
        }
      ]
    },
    "entities": {
      "patterns": [
        {
          "name": "entity.name.workflow.loj-flow",
          "match": "^(\\s*)(workflow)(\\s+)([A-Za-z_][A-Za-z0-9_-]*)(\\s*:)",
          "captures": {
            "2": { "name": "storage.type.definition.loj-flow" },
            "4": { "name": "entity.name.section.loj-flow" }
          }
        },
        {
          "name": "entity.name.state.loj-flow",
          "match": "^(\\s{4,})([A-Z][A-Z0-9_]*)(\\s*:)",
          "captures": {
            "2": { "name": "entity.name.state.loj-flow" }
          }
        },
        {
          "name": "entity.name.transition.loj-flow",
          "match": "^(\\s{4,})([a-z][A-Za-z0-9_-]*)(\\s*:)",
          "captures": {
            "2": { "name": "entity.name.transition.loj-flow" }
          }
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.section.loj-flow",
          "match": "^(\\s*)(model|field|states|wizard|steps|transitions|label|name|completesWith|surface|allow|from|to)(\\s*:)"
        },
        {
          "name": "constant.language.surface.loj-flow",
          "match": "\\b(form|read|workflow)\\b"
        },
        {
          "name": "constant.language.enum-like.loj-flow",
          "match": "\\b[A-Z][A-Z0-9_]*\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.logic.loj-flow",
          "match": "(==|!=|>=|<=|>|<|\\|\\||&&)"
        }
      ]
    },
    "scalars": {
      "patterns": [
        {
          "name": "string.quoted.double.loj-flow",
          "begin": "\"",
          "end": "\""
        },
        {
          "name": "string.quoted.single.loj-flow",
          "begin": "'",
          "end": "'"
        },
        {
          "name": "constant.numeric.loj-flow",
          "match": "\\b\\d+(?:\\.\\d+)?\\b"
        }
      ]
    }
  }
}
