model Member:
  name: string @required
  email: string @required @email
  membershipNumber: string @required
  phone: string @required
  preferredAirport: string @required
  recoveryDeskChannel: string @required
  disruptionSupportTier: string @required
  supportNote: string
  historyServiceNote: string
  tier: enum(STANDARD, GOLD) @required
  bookings: hasMany(Booking, by: member)
