**/generated/
**/generated-fastapi/
.artifacts/
.rdsl-dev/
.sdsl-dev/

# --- Local Environment ---
.env.local
.env.*.local
tmp/

# --- Testing ---
playwright-report/
test-results/

# --- Skills ---
