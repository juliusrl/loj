# --- OS Files ---
.DS_Store
Thumbs.db
*.swp
*.swo

# --- IDE Settings ---
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# --- Node.js / Dependencies ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.eslintcache
.stylelintcache

# --- Build Outputs ---
**/dist/
**/target/
**/build/
**/bin/
*.tsbuildinfo
examples/**/.artifacts

# --- Python ---
__pycache__/
.venv/
.pytest_cache/
*.pyc

# --- Java / Maven ---
.m2/

