    { "id": "resource.users.create.role", "type": "viewFieldExists", "resource": "users", "view": "create", "field": "role" },
    { "id": "resource.users.create.redirect", "type": "effectExists", "resource": "users", "view": "create", "effectType": "redirect", "target": "users.list" },
    { "id": "resource.users.create.toast", "type": "effectExists", "resource": "users", "view": "create", "effectType": "toast", "message": "User created" }
