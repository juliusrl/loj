    { "id": "resource.users.edit.allowIf", "type": "viewRuleEquals", "resource": "users", "view": "edit", "rule": "allowIf", "source": "builtin", "canonicalExpr": "hasRole(currentUser, \"admin\")" },
    { "id": "resource.users.edit.enforce", "type": "viewRuleEquals", "resource": "users", "view": "edit", "rule": "enforce", "source": "builtin", "canonicalExpr": "hasRole(currentUser, \"admin\")" },
