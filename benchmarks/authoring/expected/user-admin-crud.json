    { "id": "page.dashboard.chart", "type": "pageBlockExists", "page": "dashboard", "blockType": "chart", "title": "Active Sessions", "data": "query.sessions.daily" },
    { "id": "nav.dashboard", "type": "navItemExists", "group": "System", "label": "Overview", "target": "page.dashboard" },
