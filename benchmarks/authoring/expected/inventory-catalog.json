{
  "artifact": "rdsl.authoring-expected",
  "schemaVersion": "0.1.0",
  "taskId": "inventory-catalog",
  "budgets": {
    "maxWarnings": 0,
    "maxEscapePercent": 20,
    "maxExprCount": 0,
    "maxFnCount": 0,
    "maxCustomCount": 0
  },
  "checks": [
    { "id": "app.name", "type": "appNameEquals", "value": "Inventory Catalog" },
    { "id": "compiler.target", "type": "compilerTargetEquals", "value": "react" },
    { "id": "page.dashboard", "type": "pageExists", "page": "dashboard", "pageType": "dashboard", "title": "Catalog Overview" },
    { "id": "page.dashboard.metric", "type": "pageBlockExists", "page": "dashboard", "blockType": "metric", "title": "Total Products", "data": "query.products.count" },
    { "id": "page.dashboard.chart", "type": "pageBlockExists", "page": "dashboard", "blockType": "chart", "title": "Stock Movement", "data": "query.products.stockTrend" },
    { "id": "nav.dashboard", "type": "navItemExists", "group": "Catalog", "label": "Overview", "target": "page.dashboard" },
    { "id": "nav.products", "type": "navItemExists", "group": "Catalog", "label": "Products", "target": "resource.products.list" },
    { "id": "model.product", "type": "modelExists", "model": "Product" },
    { "id": "model.product.name", "type": "modelFieldExists", "model": "Product", "field": "name", "fieldType": "string", "decorators": ["required", "minLen"] },
    { "id": "model.product.sku", "type": "modelFieldExists", "model": "Product", "field": "sku", "fieldType": "string", "decorators": ["required", "unique"] },
    { "id": "model.product.category", "type": "modelFieldExists", "model": "Product", "field": "category", "fieldType": "enum", "enumValues": ["software", "hardware", "service"] },
    { "id": "model.product.status", "type": "modelFieldExists", "model": "Product", "field": "status", "fieldType": "enum", "enumValues": ["active", "archived"] },
    { "id": "model.product.updatedAt", "type": "modelFieldExists", "model": "Product", "field": "updatedAt", "fieldType": "datetime", "decorators": ["auto"] },
    { "id": "resource.products", "type": "resourceExists", "resource": "products", "model": "Product", "api": "/api/products", "views": ["list", "edit", "create"] },
    { "id": "resource.products.filter.sku", "type": "listFilterExists", "resource": "products", "field": "sku" },
    { "id": "resource.products.filter.category", "type": "listFilterExists", "resource": "products", "field": "category" },
    { "id": "resource.products.filter.status", "type": "listFilterExists", "resource": "products", "field": "status" },
    { "id": "resource.products.column.name", "type": "listColumnExists", "resource": "products", "field": "name", "decorators": ["sortable"] },
    { "id": "resource.products.column.sku", "type": "listColumnExists", "resource": "products", "field": "sku", "decorators": ["sortable"] },
    { "id": "resource.products.column.category", "type": "listColumnExists", "resource": "products", "field": "category", "decorators": ["tag"] },
    { "id": "resource.products.column.status", "type": "listColumnExists", "resource": "products", "field": "status", "decorators": ["badge"] },
    { "id": "resource.products.column.updatedAt", "type": "listColumnExists", "resource": "products", "field": "updatedAt", "decorators": ["date"] },
    { "id": "resource.products.action.create", "type": "actionExists", "resource": "products", "action": "create" },
    { "id": "resource.products.action.edit", "type": "actionExists", "resource": "products", "action": "edit" },
    { "id": "resource.products.action.delete", "type": "actionExists", "resource": "products", "action": "delete", "confirm": "Archive this product?" },
    { "id": "resource.products.pagination", "type": "paginationEquals", "resource": "products", "size": 40, "style": "numbered" },
    { "id": "resource.products.edit.name", "type": "viewFieldExists", "resource": "products", "view": "edit", "field": "name" },
    { "id": "resource.products.edit.sku", "type": "viewFieldExists", "resource": "products", "view": "edit", "field": "sku", "decorators": ["disabled"] },
    { "id": "resource.products.edit.category", "type": "viewFieldExists", "resource": "products", "view": "edit", "field": "category", "decorators": ["select"] },
    { "id": "resource.products.edit.status", "type": "viewFieldExists", "resource": "products", "view": "edit", "field": "status", "decorators": ["select"] },
    { "id": "resource.products.edit.allowIf", "type": "viewRuleEquals", "resource": "products", "view": "edit", "rule": "allowIf", "source": "builtin", "canonicalExpr": "hasRole(currentUser, \"catalog_manager\")" },
    { "id": "resource.products.edit.enforce", "type": "viewRuleEquals", "resource": "products", "view": "edit", "rule": "enforce", "source": "builtin", "canonicalExpr": "hasRole(currentUser, \"catalog_manager\")" },
    { "id": "resource.products.edit.invalidate", "type": "effectExists", "resource": "products", "view": "edit", "effectType": "invalidate", "target": "products" },
    { "id": "resource.products.edit.toast", "type": "effectExists", "resource": "products", "view": "edit", "effectType": "toast", "message": "Product saved" },
    { "id": "resource.products.create.name", "type": "viewFieldExists", "resource": "products", "view": "create", "field": "name" },
    { "id": "resource.products.create.sku", "type": "viewFieldExists", "resource": "products", "view": "create", "field": "sku" },
    { "id": "resource.products.create.category", "type": "viewFieldExists", "resource": "products", "view": "create", "field": "category", "decorators": ["select"] },
    { "id": "resource.products.create.status", "type": "viewFieldExists", "resource": "products", "view": "create", "field": "status", "decorators": ["select"] },
    { "id": "resource.products.create.redirect", "type": "effectExists", "resource": "products", "view": "create", "effectType": "redirect", "target": "products.list" },
    { "id": "resource.products.create.toast", "type": "effectExists", "resource": "products", "view": "create", "effectType": "toast", "message": "Product created" }
  ]
}
