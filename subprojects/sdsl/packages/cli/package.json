{
  "name": "@loj-lang/sdsl-cli",
  "version": "0.5.4",
  "description": "Backend-family developer CLI for .api.loj projects (legacy alias: .sdsl)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "license": "Apache-2.0",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20.19.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "sdsl": "./dist/index.js"
  },
  "scripts": {
    "build": "npm run build --workspace=@loj-lang/sdsl-compiler && tsc",
    "exec": "node scripts/exec-from-init-cwd.mjs",
    "test": "npm run build --workspace=@loj-lang/sdsl-compiler && vitest run"
  },
  "dependencies": {
    "@loj-lang/sdsl-compiler": "^0.5.1"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
