{
  "name": "loj",
  "private": true,
  "version": "0.5.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/juliusrl/loj"
  },
  "description": "Loj alpha workspace — AI-native sibling DSL family for frontend and backend code generation",
  "workspaces": [
    "packages/*",
    "examples/*",
    "subprojects/*/packages/*",
    "subprojects/*/examples/*"
  ],
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "build:compiler": "npm run build --workspace=@loj-lang/rdsl-compiler",
    "ci:beta-candidate": "npm run phase3:preflight && npm run ci:beta-gates && npm run benchmark:authoring:fixtures",
    "ci:build-test": "npm run build && npm test",
    "ci:generated-fastapi-syntax": "npm run py:compile:fastapi --workspace=@loj/example-user-service",
    "ci:generated-fastapi-pytest": "npm run py:test:fastapi --workspace=@loj/example-user-service",
    "ci:generated-spring": "npm run mvn:test --workspace=@loj/example-user-service",
    "ci:fullstack-e2e": "npm run e2e --workspace=@loj/example-fullstack-user-admin",
    "ci:install-rdsl-host-deps": "node scripts/install-rdsl-host-deps.mjs",
    "ci:release-packaging": "npm run build && npm run release:audit && npm run compat:audit",
    "ci:beta-gates": "npm run ci:build-test && npm run ci:generated-spring && npm run ci:generated-fastapi-pytest && npm run ci:fullstack-e2e && npm run ci:release-packaging",
    "demo": "npm run build:compiler && node scripts/demo.mjs",
    "demo:sdsl": "npm run build:generated --workspace=@loj/example-user-service",
    "demo:sdsl:fastapi": "npm run build:generated:fastapi --workspace=@loj/example-user-service",
    "demo:loj": "npm run build:generated --workspace=@loj/example-fullstack-user-admin",
    "demo:loj:fastapi": "npm run build:generated:fastapi --workspace=@loj/example-fullstack-user-admin",
    "demo:loj:dev": "npm run dev --workspace=@loj/example-fullstack-user-admin",
    "demo:loj:dev:fastapi": "npm run dev:fastapi --workspace=@loj/example-fullstack-user-admin",
    "demo:loj:e2e": "npm run e2e --workspace=@loj/example-fullstack-user-admin",
    "demo:loj:e2e:fastapi": "npm run e2e:fastapi --workspace=@loj/example-fullstack-user-admin",
    "demo:loj:invoice": "npm run build:generated --workspace=@loj/example-fullstack-invoice-backoffice",
    "demo:loj:invoice:fastapi": "npm run build:generated:fastapi --workspace=@loj/example-fullstack-invoice-backoffice",
    "demo:loj:invoice:dev": "npm run dev --workspace=@loj/example-fullstack-invoice-backoffice",
    "demo:loj:invoice:dev:fastapi": "npm run dev:fastapi --workspace=@loj/example-fullstack-invoice-backoffice",
    "demo:loj:invoice:proof": "npm run proof --workspace=@loj/example-fullstack-invoice-backoffice",
    "demo:loj:invoice:publish-preview": "npm run publish-preview --workspace=@loj/example-fullstack-invoice-backoffice",
    "demo:loj:invoice:pack": "npm run demo-pack --workspace=@loj/example-fullstack-invoice-backoffice",
    "demo:loj:invoice:pack:fastapi": "npm run demo-pack:fastapi --workspace=@loj/example-fullstack-invoice-backoffice",
    "demo:loj:booking-proof": "npm run build:generated --workspace=@loj/example-fullstack-flight-booking-proof",
    "demo:loj:booking-proof:fastapi": "npm run build:generated:fastapi --workspace=@loj/example-fullstack-flight-booking-proof",
    "demo:loj:booking-proof:e2e": "npm run e2e --workspace=@loj/example-fullstack-flight-booking-proof",
    "demo:loj:booking-proof:e2e:fastapi": "npm run e2e:fastapi --workspace=@loj/example-fullstack-flight-booking-proof",
    "demo:loj:booking-proof:record": "npm run record:e2e --workspace=@loj/example-fullstack-flight-booking-proof",
    "demo:loj:booking-proof:proof": "npm run proof --workspace=@loj/example-fullstack-flight-booking-proof",
    "demo:loj:booking-proof:measure": "npm run measure:escape --workspace=@loj/example-fullstack-flight-booking-proof",
    "local:prepublish:smoke": "node scripts/local-prepublish-smoke.mjs",
    "snapshot:public": "node scripts/create-public-snapshot.mjs",
    "benchmark:authoring:prompts": "npm run build --workspace=@loj-lang/benchmark-core && npm run exec --workspace=@loj-lang/benchmark-core -- export-prompts",
    "benchmark:authoring:fixtures": "npm run build --workspace=@loj-lang/benchmark-core && npm run exec --workspace=@loj-lang/benchmark-core -- run --submissions benchmarks/authoring/fixtures/docs-only-golden --report-dir benchmarks/reports/local-fixture",
    "compat:audit": "node scripts/compatibility-audit.mjs",
    "phase3:preflight": "node scripts/phase3-preflight.mjs",
    "release:audit": "node scripts/release-audit.mjs",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present"
  },
  "keywords": [
    "dsl",
    "react",
    "ai-native",
    "declarative",
    "admin",
    "code-generation"
  ],
  "license": "Apache-2.0"
}
